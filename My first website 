<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Random Fact Generator</title>

  <style>
    body {
      margin: 0;
      height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      background: linear-gradient(135deg, #0f172a, #1e293b);
      font-family: Arial, sans-serif;
      color: white;
    }

    .container {
      width: 90%;
      max-width: 500px;
      background: rgba(255,255,255,0.08);
      padding: 30px;
      border-radius: 20px;
      text-align: center;
      backdrop-filter: blur(10px);
      box-shadow: 0 0 25px rgba(0,0,0,0.3);
    }

    h1 {
      margin-bottom: 20px;
      font-size: 2rem;
    }

    #fact {
      font-size: 1.2rem;
      line-height: 1.7;
      margin-bottom: 25px;
      min-height: 100px;
    }

    button {
      padding: 12px 25px;
      border: none;
      border-radius: 12px;
      background: #38bdf8;
      color: white;
      font-size: 1rem;
      cursor: pointer;
      transition: 0.3s;
    }

    button:hover {
      background: #0ea5e9;
      transform: scale(1.05);
    }
  </style>
</head>

<body>

  <div class="container">
    <h1>🌍 Random Fact</h1>

    <div id="fact">
      Click the button to discover something interesting!
    </div>

    <button onclick="generateFact()">
      Show Random Fact
    </button>
  </div>

  <script>
    const facts = [
      "Octopuses have three hearts.",
      "Bananas are technically berries.",
      "Honey never spoils.",
      "Sharks existed before trees.",
      "Your brain uses about 20% of your body's energy.",
      "A day on Venus is longer than a year on Venus.",
      "Some turtles can breathe through their backsides.",
      "The Eiffel Tower grows taller in hot weather.",
      "There are more stars in the universe than grains of sand on Earth.",
      "Wombat poop is cube-shaped."
    ];

    function generateFact() {
      const randomIndex = Math.floor(Math.random() * facts.length);
      document.getElementById("fact").innerText = facts[randomIndex];
    }
  </script>

</body>
</html>